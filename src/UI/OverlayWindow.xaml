<Window x:Class="wingman_player.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        Visibility="Collapsed"
        Title="Wingman Player">
    <Window.Background>
        <!-- #01000000: alpha=1/255, visually invisible but non-zero alpha.
             AllowsTransparency uses UpdateLayeredWindow (per-pixel alpha), so any
             pixel with alpha=0 is click-through at the OS level — WM_NCHITTEST is
             bypassed entirely. A near-zero alpha background ensures no pixel is
             fully transparent, so Windows delivers mouse events to this window and
             its WebView2 child HWND. -->
        <SolidColorBrush Color="#01000000"/>
    </Window.Background>

    <Grid>
        <wv2:WebView2 x:Name="WebView" />
    </Grid>
</Window>
