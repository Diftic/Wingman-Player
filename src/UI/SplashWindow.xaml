<Window x:Class="wingman_player.UI.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wingman Player"
        Width="420" Height="310"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#0d1b2a">

    <Grid>
        <!-- Background image — fills the entire splash window -->
        <Image Source="/Assets/main_logo.png"
               Stretch="UniformToFill"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Bottom gradient — darkens the lower band so the F9 prompt stays readable
             over any background variation in the artwork. -->
        <Rectangle VerticalAlignment="Bottom" Height="110" IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#000d1b2a" Offset="0.0"/>
                    <GradientStop Color="#CC0d1b2a" Offset="1.0"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Top accent line (above the image) -->
        <Rectangle Height="3" VerticalAlignment="Top" Fill="#22d3ee"/>

        <!-- Update banner (collapsed until an update is found) -->
        <Border x:Name="UpdateBanner"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                Margin="0,3,0,0"
                Background="#0a2318"
                BorderBrush="#22d3ee"
                BorderThickness="0,0,0,1"
                Height="36">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="UpdateLabel"
                           Grid.Column="0"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#22d3ee"
                           VerticalAlignment="Center"/>
                <Button x:Name="UpdateButton"
                        Grid.Column="1"
                        Click="OnUpdateClick"
                        FontFamily="Segoe UI"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Padding="10,4"
                        Background="#22d3ee"
                        Foreground="#09131f"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Hotkey prompt — overlaid near the bottom -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,38">
            <TextBlock Text="Press "
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Foreground="#cfeefa"
                       VerticalAlignment="Center"/>
            <Border Background="#132238"
                    BorderBrush="#2a4a6b"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,4"
                    VerticalAlignment="Center">
                <TextBlock x:Name="HotkeyLabel"
                           Text="F3"
                           FontFamily="Consolas"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#22d3ee"/>
            </Border>
            <TextBlock Text=" to open the player"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Foreground="#cfeefa"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Bottom hint -->
        <TextBlock Text="Right-click the tray icon to exit"
                   FontFamily="Segoe UI"
                   FontSize="10"
                   Foreground="#94a3b8"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,14"/>
    </Grid>
</Window>
